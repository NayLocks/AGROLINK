<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>404 - Page introuvable</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      background: radial-gradient(circle at top, #e9f2ff 0%, #f8fbff 40%, #ffffff 100%);
    }
    .error-code {
      font-size: clamp(5rem, 18vw, 10rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.06em;
      color: #0d6efd;
      text-shadow: 0 10px 30px rgba(13, 110, 253, 0.15);
    }
    .error-card {
      max-width: 760px;
      border: 1px solid rgba(13, 110, 253, 0.08);
      border-radius: 1.5rem;
      box-shadow: 0 1rem 3rem rgba(13, 110, 253, 0.08);
      backdrop-filter: blur(8px);
    }
    .icon-wrap {
      width: 72px;
      height: 72px;
      border-radius: 1.25rem;
      background: rgba(13, 110, 253, 0.1);
      color: #0d6efd;
    }
  </style>
</head>
<body>
  <main class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
    <section class="error-card bg-white p-4 p-md-5 text-center w-100">
      <div class="d-flex justify-content-center mb-4">
        <div class="icon-wrap d-flex align-items-center justify-content-center fs-2">!</div>
      </div>
      <div class="error-code mb-2">500</div>
      <h1 class="fw-bold mb-3">Erreur interne du serveur</h1>
      <p class="text-secondary fs-5 mb-4 mx-auto" style="max-width: 560px;">
      </p>
      <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
        <a href="#" class="btn btn-primary btn-lg px-4">Retour à l'accueil</a>
        <button class="btn btn-outline-secondary btn-lg px-4" onclick="history.back()">Page précédente</button>
      </div>
      <div class="mt-5 pt-4 border-top text-secondary small">
        Code erreur 500 · Vérifiez l'URL ou contactez le support si le problème persiste.
      </div>
    </section>
  </main>
</body>
</html>