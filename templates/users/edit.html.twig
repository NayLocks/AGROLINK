{% extends 'base.html.twig' %}

{% block title %}Modifier l'utilisateur{% endblock %}

{% block body %}
    <form method="post">
        <input type="hidden" name="_token" value="{{ csrf_token('edit_user_' ~ user.id) }}">
    
        <div class="mb-8">
            <a href="{{ path('users_index') }}" class="flex items-center gap-2 text-sm font-bold text-slate-400 hover:text-blue-600 mb-4 transition-all">
                <span class="material-symbols-outlined text-lg">arrow_back</span> Retour aux utilisateurs
            </a>
            
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
                <div class="flex items-center gap-4">
                    <div class="h-20 w-20 rounded-3xl bg-blue-100 flex items-center justify-center text-blue-700 text-2xl font-black shadow-sm">{{ user.lastname|slice(0,1) }} {{ user.firstName|slice(0,1) }}</div>
                    <div>
                        <div class="flex items-center gap-3">
                            <h2 class="text-3xl font-black text-slate-900">{{ user.firstName }} {{ user.lastName }}</h2>
                        </div>
                        <p class="text-slate-500 font-medium">{{ user.jobFunction }}<br>Société par defaut · {{ user.companyActive.name == 'DEFAUT' ? 'NON RENSEIGNEE' : user.companyActive.name }}</p>
                    </div>
                </div>
                
                <div class="flex gap-3">
                    <a href="{{ path('users_index') }}" class="bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-slate-50 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">close</span> Annuler
                    </a>
                    <button type="submit" name="VALIDATION" class="bg-blue-600 text-white px-6 py-2.5 rounded-xl font-bold text-sm shadow-lg shadow-blue-200 hover:bg-blue-700 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">save</span> Enregistrer
                    </button>
                </div>
            </div>
        </div>
    
        <!-- Onglets -->
        <div class="card p-1 mb-8 bg-slate-100/50 flex gap-1 w-fit">
            <button type="button" onclick="switchTab('profile')" class="tab-btn px-6 py-2 rounded-xl text-sm font-bold transition-all tab-profile bg-white text-blue-600 shadow-sm">
                Profil & Rôles
            </button>
            <button type="button" onclick="switchTab('liaison')" class="tab-btn px-6 py-2 rounded-xl text-sm font-bold transition-all tab-liaison text-slate-500 hover:text-slate-700">
                Liaisons Sociétés
            </button>
        </div>
    
        <div id="tab-profile" class="tab-content">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="card p-6 flex flex-col items-center text-center">
                    <div class="h-24 w-24 rounded-3xl bg-blue-100 flex items-center justify-center text-blue-700 text-2xl font-black mb-4">{{ user.lastname|slice(0,1) }} {{ user.firstName|slice(0,1) }}</div>
                    <h3 class="text-lg font-bold text-slate-900">{{ user.firstName }} {{ user.lastName }}</h3>
                    <p class="text-sm text-slate-500">{{ user.jobFunction }}</p>
                    <button class="mt-6 w-full px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-slate-200">Changer l'avatar</button>
                </div>
                <div class="lg:col-span-2 space-y-6">
                    <div class="card p-6">
                        <h4 class="text-sm font-bold text-slate-900 mb-4">Informations personnelles</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <input type="text" value="{{ user.firstName }}" name="firstName" placeholder="John" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                            <input type="text" value="{{ user.lastName }}" name="lastName" placeholder="Doe" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                            <input type="email" value="{{ user.email }}" name="email" placeholder="john.doe@example.com" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500 md:col-span-2">
                        </div>
                    </div>

                    <div class="card p-6">
                        <h4 class="text-sm font-bold text-slate-900 mb-4">Rôle et société par défaut</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <input type="text" value="{{ user.jobFunction }}" name="jobFunction" placeholder="Fonction" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                            <select name="companyActive" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                                    <option value="">Sélectionner une société</option>
                                {% for company in user.companies %}
                                    <option value="{{ company.id }}" {{ user.companyActive.id == company.id ? 'selected' : '' }}>{{ company.name }}</option>
                                {% endfor %}
                            </select>
                            <select name="isActived" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                                <option value="1" {{ user.isActived ? 'selected' : '' }}>Actif</option>
                                <option value="0" {{ not user.isActived ? 'selected' : '' }}>Inactif</option>
                            </select>
                        </div>  
                    </div>

                    <div class="card p-6">
                        <h4 class="text-sm font-bold text-slate-900 mb-4">Sécurité</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <input type="password" placeholder="Nouveau mot de passe" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                            <input type="password" placeholder="Confirmer le mot de passe" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div class="mt-4 flex items-center justify-between bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm">
                            <span class="text-slate-600 font-medium">Forcer la réinitialisation du mot de passe à la prochaine connexion</span>
                            <input type="checkbox" class="h-4 w-4 text-blue-600">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- TAB LIAISONS SOCIÉTÉS -->
        <div id="tab-liaison" class="tab-content hidden">
            <div class="card p-8">
                <h4 class="text-lg font-bold text-slate-900 mb-2">Sociétés autorisées</h4>
                <p class="text-sm text-slate-500 mb-8">Définissez les entités auxquelles <strong>{{ user.firstName }} {{ user.lastName }}</strong> peut accéder et changer via son interface.</p>
                    
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {% for c in companies %}
                        <label class="flex items-center justify-between p-5 bg-slate-50 rounded-2xl border-2 transition-all cursor-pointer {% if c.id == user.companyActive.id %}border-blue-200 bg-blue-50/30{% else %}border-slate-100 hover:border-slate-200{% endif %}">
                            <div class="flex items-center gap-4">
                                <div class="h-12 w-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400">
                                    <span class="material-symbols-outlined">domain</span>
                                </div>

                                <div>
                                    <p class="text-sm font-bold text-slate-900">{{ c.name }}</p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase">{{ c.legal }}</p>
                                </div>
                            </div>
                        
                            <div class="flex items-center gap-4">
                                {% if c.id == user.companyActive.id %}
                                    <span class="text-[10px] font-black text-blue-600 uppercase bg-blue-100 px-2 py-1 rounded">Société par défaut</span>
                                {% endif %}
                                <input type="checkbox" name="companies[]" value="{{ c.id }}" class="w-6 h-6 rounded-lg border-slate-300 text-blue-600 focus:ring-blue-500" {% if c in user.companies %}checked{% endif %}>
                            </div>
                        </label>
                    {% endfor %}
                </div>
            </div>
        </div>
    </form>
{% endblock %}