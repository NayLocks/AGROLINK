{% extends 'base.html.twig' %}

{% set isEdit = company is defined and company.id is not null %}

{% block title %}
    {{ isEdit ? 'Modifier la société' : 'Création d\'une société' }}
{% endblock %}

{% block body %}
    <form method="post">
        <input type="hidden" name="_token"value="{{ csrf_token(isEdit ? 'edit_companies_' ~ company.id : 'add_companies') }}">

        <div class="mb-8">
            <a href="{{ path('companies_index') }}" class="flex items-center gap-2 text-sm font-bold text-slate-400 hover:text-blue-600 mb-4 transition-all">
                <span class="material-symbols-outlined text-lg">arrow_back</span> Retour aux sociétés
            </a>
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
                <div class="flex items-center gap-4">
                    <div class="h-16 w-16 rounded-2xl bg-slate-100 flex items-center justify-center text-slate-400">
                        <span class="material-symbols-outlined text-3xl">domain</span>
                    </div>
                    <div>
                        <h2 class="text-3xl font-black text-slate-900">
                            {{ isEdit ? company.name : 'Nouvelle société' }}
                            {% if isEdit and company.businessName %}({{ company.businessName }}){% endif %}
                        </h2>
                        <p class="text-slate-500 font-medium">Paramétrage de l'entité juridique</p>
                    </div>
                </div>
                <div class="flex gap-3">
                    <a href="{{ path('companies_index') }}" class="bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-slate-50 transition-all">Annuler</a>
                    <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-xl font-bold text-sm shadow-lg shadow-blue-200 hover:bg-blue-700 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">save</span> Enregistrer les modifications
                    </button>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                <div class="card p-6">
                    <h4 class="text-sm font-bold text-slate-900 mb-4">Identification Légale</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Raison Sociale</label>
                            <input type="text" value="{{ isEdit ? company.name : '' }}" name="name" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Nom Commercial</label>
                            <input type="text" value="{{ isEdit ? company.businessName : '' }}" name="businessName" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Forme juridique</label>
                            <input type="text" value="{{ company.legal }}" name="legal" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">SIRET</label>
                            <input type="text" value="{{ company.siret }}" name="siret" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Numéro TVA</label>
                            <input type="text" value="{{ company.vat }}" name="vat" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Numéro TVA</label>
                            <input type="text" value="{{ company.vat }}" name="vat" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Numéro TVA</label>
                            <input type="text" value="{{ company.vat }}" name="vat" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Numéro TVA</label>
                            <input type="text" value="{{ company.vat }}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                    </div>
                </div>

                <div class="card p-6">
                    <h4 class="text-sm font-bold text-slate-900 mb-4">Siège Social & Contact</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-1 md:col-span-2">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Adresse</label>
                            <input type="text" value="{{ company.address1 }}" name="address1" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Complément d'adresse</label>
                            <input type="email" value="{{ company.address2 }}" name="address2" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Boite Postale</label>
                            <input type="text" value="{{ company.poBox }}" name="poBox" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Code Postal</label>
                            <input type="text" value="{{ company.postalCode }}" name="postalCode" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Ville</label>
                            <input type="text" value="{{ company.city }}" name="city" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <select name="isActived" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="1" {{ company.isActived ? 'selected' : '' }}>Actif</option>
                            <option value="0" {{ not company.isActived ? 'selected' : '' }}>Inactif</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                <div class="card p-6">
                    <h4 class="text-sm font-bold text-slate-900 mb-4">Configuration Facture</h4>
                    <div class="space-y-4">
                        <div class="border-2 border-dashed border-slate-200 rounded-2xl p-8 flex flex-col items-center justify-center text-center">
                            <span class="material-symbols-outlined text-slate-300 text-4xl mb-2">upload_file</span>
                            <p class="text-xs font-bold text-slate-500">Logo sur les documents</p>
                            <button class="mt-3 text-[10px] font-bold text-blue-600 uppercase tracking-widest">Parcourir</button>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Devise par défaut</label>
                            <select class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm outline-none">
                                <option>Euro (€)</option>
                                <option>Dollar ($)</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
{% endblock %}